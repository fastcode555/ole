<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mysite.videoserver</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/infinity/.nvm/versions/node/v22.14.0/bin/node</string>
        <string>/Users/infinity/Code/githubs/ole/server.js</string>
    </array>

    <key>WorkingDirectory</key>
